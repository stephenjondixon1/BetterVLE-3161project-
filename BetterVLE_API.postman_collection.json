						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{auth_token}}" }],
						"body": { "mode": "raw", "raw": "{\n\t\"submission_content\": \"https://school.edu/submissions/student52_a1.pdf\"\n}" },
