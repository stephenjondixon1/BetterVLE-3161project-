					"name": "Update Assignment (Lecturer)",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{auth_token}}" }],
						"body": { "mode": "raw", "raw": "{\n\t\"weight\": 30\n}" },
						"url": { "raw": "{{base_url}}/assignments/assignments/1", "host": ["{{base_url}}"], "path": ["assignments", "assignments", "1"] },
						"description": "PUT /api/assignments/assignments/:assignmentId — Lecturer/admin only."
