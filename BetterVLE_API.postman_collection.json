				{
					"name": "Delete Assignment (Lecturer)",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
						"url": { "raw": "{{base_url}}/assignments/assignments/1", "host": ["{{base_url}}"], "path": ["assignments", "assignments", "1"] },
						"description": "DELETE /api/assignments/assignments/:assignmentId — cascades to submissions. Lecturer/admin only."
