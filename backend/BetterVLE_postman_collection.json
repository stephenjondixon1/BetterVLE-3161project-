						],
						"url": {
							"raw": "{{base_url}}/forums/courses/COMP0001/forums",
							"host": ["{{base_url}}"],
							"path": ["forums", "courses", "COMP0001", "forums"]
						},
						"description": "GET /api/forums/courses/:courseCode/forums"
					},
					"response": []
				},
				{
					"name": "Create Discussion Thread",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"title\": \"Help with Network Security Lab\",\n\t\"starter_post\": \"Can someone explain how to set up the firewall rules for Lab 3?\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/forums/forums/1/threads",
							"host": ["{{base_url}}"],
							"path": ["forums", "forums", "1", "threads"]
						},
						"description": "POST /api/forums/forums/:forumId/threads. created_by auto-set from JWT."
					},
					"response": []
				},
				{
					"name": "Retrieve Threads for Forum",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/forums/forums/1/threads",
							"host": ["{{base_url}}"],
							"path": ["forums", "forums", "1", "threads"]
						},
						"description": "GET /api/forums/forums/:forumId/threads"
					},
					"response": []
				},
				{
					"name": "Reply to Thread",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"content\": \"Make sure you allow inbound traffic on port 443.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/forums/threads/1/replies",
							"host": ["{{base_url}}"],
							"path": ["forums", "threads", "1", "replies"]
						},
						"description": "POST /api/forums/threads/:threadId/replies. Top-level reply (no parent)."
					},
					"response": []
				},
				{
					"name": "Reply to a Reply (Nested)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"content\": \"That worked! Thanks, port 443 was blocked.\",\n\t\"parent_reply_id\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/forums/threads/1/replies",
							"host": ["{{base_url}}"],
							"path": ["forums", "threads", "1", "replies"]
						},
						"description": "POST /api/forums/threads/:threadId/replies with parent_reply_id for nested reply."
					},
					"response": []
				},
				{
					"name": "Retrieve Replies for Thread",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/forums/threads/1/replies",
							"host": ["{{base_url}}"],
							"path": ["forums", "threads", "1", "replies"]
						},
						"description": "GET /api/forums/threads/:threadId/replies"
					},
					"response": []
				}
			]
		},
