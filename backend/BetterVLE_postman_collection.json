{
	"info": {
		"_postman_id": "comp3161-bettervle-api",
		"name": "COMP3161 BetterVLE API",
		"description": "Postman collection for the BetterVLE Course Management System API.\n\nBase URL default: http://localhost:3000/api\n\nWorkflow:\n1. Register users (admin, lecturer, student)\n2. Login as admin → token auto-saved\n3. Create course, assign lecturer, enroll students\n4. Login as lecturer → create content, assignments, calendar events, forums\n5. Login as student → enroll, submit assignments, post in forums\n6. Login as admin → view reports",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000/api",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "POST /api/auth/register and POST /api/auth/login",
			"item": [
				{
					"name": "Register Student",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"teststudent1\",\n\t\"password\": \"pass123\",\n\t\"role\": \"student\",\n\t\"first_name\": \"Matthew\",\n\t\"last_name\": \"Brown\",\n\t\"major\": \"Computer Science\",\n\t\"department\": \"Computing\",\n\t\"gpa\": 3.5\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Register Lecturer",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"testlecturer1\",\n\t\"password\": \"pass123\",\n\t\"role\": \"lecturer\",\n\t\"first_name\": \"Jane\",\n\t\"last_name\": \"Smith\",\n\t\"department\": \"Computing\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Register Admin",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"testadmin1\",\n\t\"password\": \"admin123\",\n\t\"role\": \"admin\",\n\t\"admin_name\": \"Test Admin\",\n\t\"admin_email\": \"testadmin@email.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Login as Admin",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"var jsonData = pm.response.json();",
								"if (jsonData.token) {",
								"    pm.collectionVariables.set('auth_token', jsonData.token);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"admin1\",\n\t\"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login as the seeded admin (user_id 1). Token auto-saved."
					},
					"response": []
				},
				{
					"name": "Login as Lecturer",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"var jsonData = pm.response.json();",
								"if (jsonData.token) {",
								"    pm.collectionVariables.set('auth_token', jsonData.token);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"lecturer2\",\n\t\"password\": \"pass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login as lecturer 2 (Bradley Terry). Token auto-saved."
					},
					"response": []
				},
				{
					"name": "Login as Student",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"var jsonData = pm.response.json();",
								"if (jsonData.token) {",
								"    pm.collectionVariables.set('auth_token', jsonData.token);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"user_name\": \"student52\",\n\t\"password\": \"pass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Login as student 52 (Robin Anderson). Token auto-saved."
					},
					"response": []
				}
			]
		},
		{
			"name": "Courses",
			"description": "Course CRUD and enrollment.",
			"item": [
				{
					"name": "Create Course (Admin)",
