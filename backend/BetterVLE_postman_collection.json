							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": {
							"raw": "{{base_url}}/forums/courses/COMP0001/forums",
							"host": ["{{base_url}}"],
							"path": ["forums", "courses", "COMP0001", "forums"]
