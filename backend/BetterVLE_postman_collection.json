						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{auth_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"course_code\": \"COMP0201\",\n\t\"course_title\": \"Advanced Databases\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/courses",
							"host": ["{{base_url}}"],
							"path": ["courses"]
						},
						"description": "Admin-only. created_by is auto-set from JWT."
					},
					"response": []
				},
				{
					"name": "Retrieve All Courses",
					"request": {
						"method": "GET",
						"header": [],
